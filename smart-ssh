#!/bin/bash

# smart-ssh - Local network-based SSH connection script
# Automatically chooses between regular public key auth (home) and security key auth (away)
# Usage: smart-ssh <hostname>
# Example: smart-ssh hostname

# Configuration file path (XDG Base Directory compliant)
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/smart-ssh"
CONFIG_FILE="$CONFIG_DIR/config"

# Default configuration values
DEFAULT_HOME_NETWORK="192.168.1.0/24"
DEFAULT_HOME_GATEWAY_MAC=""
DEFAULT_SECURITY_KEY_PATH="$HOME/.ssh/id_ed25519_sk"
DEFAULT_TAILSCALE_AS_HOME="true"
DEFAULT_LOG_LEVEL="info"
DEFAULT_OIDC_ENABLED="false"
DEFAULT_OIDC_ISSUER=""
DEFAULT_OIDC_CLIENT_ID=""
DEFAULT_OIDC_SCOPES="openid email"
DEFAULT_OIDC_CA_URL=""
DEFAULT_OIDC_CA_PROVISIONER="oidc"
DEFAULT_OIDC_CA_MODE="api"
DEFAULT_OIDC_CERT_LIFETIME="3600"
DEFAULT_OIDC_CERT_DIR="$HOME/.ssh/oidc-certs"
DEFAULT_OIDC_AUTH_MODE="auto"

# Load configuration from file if it exists
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        # Source the config file in a safe manner
        while IFS='=' read -r key value; do
            # Skip comments and empty lines
            [[ "$key" =~ ^#.*$ ]] && continue
            [[ -z "$key" ]] && continue

            # Remove leading/trailing whitespace
            key=$(echo "$key" | xargs)
            value=$(echo "$value" | xargs)

            # Remove quotes from value if present
            value="${value%\"}"
            value="${value#\"}"
            value="${value%\'}"
            value="${value#\'}"

            case "$key" in
                HOME_NETWORK)
                    CONFIG_HOME_NETWORK="$value"
                    ;;
                HOME_GATEWAY_MAC)
                    CONFIG_HOME_GATEWAY_MAC="$value"
                    ;;
                SECURITY_KEY_PATH)
                    CONFIG_SECURITY_KEY_PATH="$value"
                    ;;
                TAILSCALE_AS_HOME)
                    CONFIG_TAILSCALE_AS_HOME="$value"
                    ;;
                LOG_LEVEL)
                    CONFIG_LOG_LEVEL="$value"
                    ;;
                OIDC_ENABLED) CONFIG_OIDC_ENABLED="$value" ;;
                OIDC_ISSUER) CONFIG_OIDC_ISSUER="$value" ;;
                OIDC_CLIENT_ID) CONFIG_OIDC_CLIENT_ID="$value" ;;
                OIDC_SCOPES) CONFIG_OIDC_SCOPES="$value" ;;
                OIDC_CA_URL) CONFIG_OIDC_CA_URL="$value" ;;
                OIDC_CA_PROVISIONER) CONFIG_OIDC_CA_PROVISIONER="$value" ;;
                OIDC_CA_MODE) CONFIG_OIDC_CA_MODE="$value" ;;
                OIDC_CERT_LIFETIME) CONFIG_OIDC_CERT_LIFETIME="$value" ;;
                OIDC_CERT_DIR) CONFIG_OIDC_CERT_DIR="$value" ;;
                OIDC_AUTH_MODE) CONFIG_OIDC_AUTH_MODE="$value" ;;
            esac
        done < "$CONFIG_FILE"
    fi
}

# Load configuration
load_config

# Configuration priority: Environment variable > Config file > Default
# Home networks (can be overridden by environment variable, comma-separated)
HOME_NETWORK="${HOME_NETWORK:-${CONFIG_HOME_NETWORK:-$DEFAULT_HOME_NETWORK}}"
# Home gateway MAC addresses (can be overridden by environment variable, comma-separated)
HOME_GATEWAY_MAC="${HOME_GATEWAY_MAC:-${CONFIG_HOME_GATEWAY_MAC:-$DEFAULT_HOME_GATEWAY_MAC}}"
# Treat Tailscale hosts as home network (can be overridden by environment variable)
TAILSCALE_AS_HOME="${TAILSCALE_AS_HOME:-${CONFIG_TAILSCALE_AS_HOME:-$DEFAULT_TAILSCALE_AS_HOME}}"
# Security key path (can be overridden by environment variable)
SECURITY_KEY_PATH="${SECURITY_KEY_PATH:-${CONFIG_SECURITY_KEY_PATH:-$DEFAULT_SECURITY_KEY_PATH}}"
# Expand ~ in SECURITY_KEY_PATH
SECURITY_KEY_PATH="${SECURITY_KEY_PATH/#\~/$HOME}"
# Log level
LOG_LEVEL="${LOG_LEVEL:-${CONFIG_LOG_LEVEL:-$DEFAULT_LOG_LEVEL}}"
# OIDC settings
OIDC_ENABLED="${OIDC_ENABLED:-${CONFIG_OIDC_ENABLED:-$DEFAULT_OIDC_ENABLED}}"
OIDC_ISSUER="${OIDC_ISSUER:-${CONFIG_OIDC_ISSUER:-$DEFAULT_OIDC_ISSUER}}"
OIDC_CLIENT_ID="${OIDC_CLIENT_ID:-${CONFIG_OIDC_CLIENT_ID:-$DEFAULT_OIDC_CLIENT_ID}}"
OIDC_SCOPES="${OIDC_SCOPES:-${CONFIG_OIDC_SCOPES:-$DEFAULT_OIDC_SCOPES}}"
OIDC_CA_URL="${OIDC_CA_URL:-${CONFIG_OIDC_CA_URL:-$DEFAULT_OIDC_CA_URL}}"
OIDC_CA_PROVISIONER="${OIDC_CA_PROVISIONER:-${CONFIG_OIDC_CA_PROVISIONER:-$DEFAULT_OIDC_CA_PROVISIONER}}"
OIDC_CA_MODE="${OIDC_CA_MODE:-${CONFIG_OIDC_CA_MODE:-$DEFAULT_OIDC_CA_MODE}}"
OIDC_CERT_LIFETIME="${OIDC_CERT_LIFETIME:-${CONFIG_OIDC_CERT_LIFETIME:-$DEFAULT_OIDC_CERT_LIFETIME}}"
OIDC_CERT_DIR="${OIDC_CERT_DIR:-${CONFIG_OIDC_CERT_DIR:-$DEFAULT_OIDC_CERT_DIR}}"
# Expand ~ in OIDC_CERT_DIR
OIDC_CERT_DIR="${OIDC_CERT_DIR/#\~/$HOME}"
OIDC_AUTH_MODE="${OIDC_AUTH_MODE:-${CONFIG_OIDC_AUTH_MODE:-$DEFAULT_OIDC_AUTH_MODE}}"

# Color output support (respects NO_COLOR environment variable)
if [ -t 1 ] && [ -z "${NO_COLOR}" ]; then
    COLOR_RESET='\033[0m'
    COLOR_RED='\033[0;31m'
    COLOR_GREEN='\033[0;32m'
    COLOR_YELLOW='\033[0;33m'
    COLOR_BLUE='\033[0;34m'
    COLOR_CYAN='\033[0;36m'
else
    COLOR_RESET=''
    COLOR_RED=''
    COLOR_GREEN=''
    COLOR_YELLOW=''
    COLOR_BLUE=''
    COLOR_CYAN=''
fi

# Log level constants
LOG_LEVEL_DEBUG=0
LOG_LEVEL_INFO=1
LOG_LEVEL_WARN=2
LOG_LEVEL_ERROR=3

# Convert log level string to number
get_log_level_number() {
    local level_lower=$(echo "$LOG_LEVEL" | tr '[:upper:]' '[:lower:]')
    case "$level_lower" in
        debug) echo $LOG_LEVEL_DEBUG ;;
        info) echo $LOG_LEVEL_INFO ;;
        warn) echo $LOG_LEVEL_WARN ;;
        error) echo $LOG_LEVEL_ERROR ;;
        *) echo $LOG_LEVEL_INFO ;;
    esac
}

CURRENT_LOG_LEVEL=$(get_log_level_number)
# Ensure CURRENT_LOG_LEVEL is set (default to INFO if empty)
CURRENT_LOG_LEVEL=${CURRENT_LOG_LEVEL:-$LOG_LEVEL_INFO}

# Print functions for colored output
print_error() {
    echo -e "${COLOR_RED}$*${COLOR_RESET}" >&2
}

print_success() {
    echo -e "${COLOR_GREEN}$*${COLOR_RESET}"
}

print_warning() {
    echo -e "${COLOR_YELLOW}$*${COLOR_RESET}"
}

print_info() {
    echo -e "${COLOR_CYAN}$*${COLOR_RESET}"
}

print_debug() {
    echo -e "${COLOR_BLUE}$*${COLOR_RESET}"
}

# Logging functions with log level support
log_error() {
    if [ "$CURRENT_LOG_LEVEL" -le "$LOG_LEVEL_ERROR" ]; then
        print_error "[ERROR] $*"
    fi
}

log_warn() {
    if [ "$CURRENT_LOG_LEVEL" -le "$LOG_LEVEL_WARN" ]; then
        print_warning "[WARN] $*"
    fi
}

log_info() {
    if [ "$CURRENT_LOG_LEVEL" -le "$LOG_LEVEL_INFO" ]; then
        print_info "[INFO] $*"
    fi
}

log_debug() {
    if [ "$CURRENT_LOG_LEVEL" -le "$LOG_LEVEL_DEBUG" ]; then
        print_debug "[DEBUG] $*"
    fi
}

# Show usage information
usage() {
    echo "Usage: $0 [OPTIONS] <hostname> [SSH_OPTIONS]"
    echo ""
    echo "Examples:"
    echo "  $0 hostname"
    echo "  $0 production-server"
    echo "  $0 hostname -v                    # Pass -v to ssh for verbose output"
    echo "  $0 hostname -p 2222               # Use custom SSH port"
    echo "  $0 -- hostname -v -p 2222         # Use -- to separate options"
    echo "  HOME_GATEWAY_MAC=aa:bb:cc:dd:ee:ff $0 hostname  # Use MAC-based detection"
    echo "  HOME_NETWORK=192.168.1.0/24,10.0.0.0/24 $0 hostname"
    echo "  SECURITY_KEY_PATH=~/.ssh/id_ecdsa_sk $0 --security-key hostname"
    echo ""
    echo "Required SSH config pattern (~/.ssh/config):"
    echo "  Host <hostname>                # Single host entry"
    echo "                                 # Regular key specified in IdentityFile"
    echo "                                 # Security key used with -i when away"
    echo ""
    echo "Smart-SSH Options:"
    echo "  --security-key, -s   Force security key authentication"
    echo "  --oidc               Force OIDC Device Flow authentication (no fallback)"
    echo "  --dry-run, -n        Show what would be executed without connecting"
    echo "  --init-config        Create default configuration file"
    echo "  --debug, -d          Show debug information"
    echo "  --help, -h           Show this help message"
    echo "  --                   End of smart-ssh options (remaining args are SSH options)"
    echo ""
    echo "SSH Options:"
    echo "  Any SSH options (like -v, -p, -L, etc.) are passed through to ssh."
    echo "  Place them after the hostname or use -- to separate them clearly."
    echo ""
    echo "Configuration:"
    echo "  Config file: $CONFIG_FILE"
    echo "  Priority: Environment variable > Config file > Default"
    echo ""
    echo "Author: https://github.com/ngc-shj/smart-ssh"
}

# Initialize configuration file
init_config() {
    if [ -f "$CONFIG_FILE" ]; then
        print_warning "Configuration file already exists: $CONFIG_FILE"
        read -rp "Overwrite? (y/N): " confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            echo "Cancelled."
            return 1
        fi
    fi

    # Create config directory if it doesn't exist
    mkdir -p "$CONFIG_DIR"

    # Create default configuration file
    cat > "$CONFIG_FILE" <<'EOF'
# smart-ssh configuration file
# This file follows the format: KEY=value
# Lines starting with # are comments

# Treat Tailscale hosts as home network (true/false)
# When enabled, connections to Tailscale nodes (100.64.0.0/10, *.ts.net)
# are treated as home network and use regular public key authentication
# Default: true
TAILSCALE_AS_HOME=true

# Home gateway MAC addresses (comma-separated, preferred detection method)
# Use 'smart-ssh --debug' to find your gateway MAC address
# Example: HOME_GATEWAY_MAC=aa:bb:cc:dd:ee:ff,11:22:33:44:55:66
HOME_GATEWAY_MAC=

# Home networks (comma-separated CIDR ranges, fallback detection method)
# Example: HOME_NETWORK=192.168.1.0/24,10.0.0.0/24,172.16.0.0/12
HOME_NETWORK=192.168.1.0/24

# Security key path
# Default: ~/.ssh/id_ed25519_sk
SECURITY_KEY_PATH=~/.ssh/id_ed25519_sk

# Log level (debug, info, warn, error)
# Default: info
LOG_LEVEL=info

# OIDC Device Flow authentication
# Enable OIDC Device Flow for certificate-based SSH authentication (true/false)
# Default: false
#OIDC_ENABLED=false

# OIDC issuer URL (must use https://)
# Example: OIDC_ISSUER=https://accounts.example.com
#OIDC_ISSUER=

# OIDC client ID registered with the issuer
# Example: OIDC_CLIENT_ID=smart-ssh-cli
#OIDC_CLIENT_ID=

# OIDC scopes (space-separated)
# Default: openid email
#OIDC_SCOPES=openid email

# CA server URL for SSH certificate signing (must use https://)
# Example: OIDC_CA_URL=https://ca.example.com
#OIDC_CA_URL=

# CA provisioner name for OIDC
# Default: oidc
#OIDC_CA_PROVISIONER=oidc

# CA mode: "api" (curl direct) - "step" is future work
# Default: api
#OIDC_CA_MODE=api

# Certificate lifetime in seconds
# Default: 3600
#OIDC_CERT_LIFETIME=3600

# Directory to cache OIDC certificates and keys
# Default: ~/.ssh/oidc-certs
#OIDC_CERT_DIR=~/.ssh/oidc-certs

# OIDC authentication mode: auto|prefer|only|disabled
#   auto     - use OIDC when sk key file is absent; no fallback on failure
#   prefer   - prefer OIDC; fall back to sk key on network/CA error (exit 2) only
#   only     - OIDC only; no fallback
#   disabled - OIDC disabled
# Default: auto
#OIDC_AUTH_MODE=auto
EOF

    print_success "Configuration file created: $CONFIG_FILE"
    echo ""
    echo "Edit the file to customize your settings:"
    echo "  ${EDITOR:-vi} $CONFIG_FILE"
    return 0
}

# Validate IP address format
validate_ip() {
    local ip="$1"
    local valid_ip_regex='^([0-9]{1,3}\.){3}[0-9]{1,3}$'

    if ! [[ "$ip" =~ $valid_ip_regex ]]; then
        return 1
    fi

    # Check each octet is 0-255
    local -a octets
    IFS='.' read -ra octets <<< "$ip"
    for octet in "${octets[@]}"; do
        if [ "$octet" -lt 0 ] || [ "$octet" -gt 255 ]; then
            return 1
        fi
    done

    return 0
}

# Validate CIDR format
validate_cidr() {
    local cidr="$1"

    if [[ ! "$cidr" =~ ^[^/]+/[0-9]+$ ]]; then
        print_error "Error: Invalid CIDR format: $cidr"
        echo "Expected format: IP/MASK (e.g., 192.168.1.0/24)" >&2
        return 1
    fi

    local network=$(echo "$cidr" | cut -d'/' -f1)
    local mask_bits=$(echo "$cidr" | cut -d'/' -f2)

    # Validate IP address
    if ! validate_ip "$network"; then
        print_error "Error: Invalid IP address in CIDR: $network"
        return 1
    fi

    # Validate mask bits (0-32)
    if [ "$mask_bits" -lt 0 ] || [ "$mask_bits" -gt 32 ]; then
        print_error "Error: Invalid network mask bits: $mask_bits (must be 0-32)"
        return 1
    fi

    return 0
}

# Get gateway IP address
get_gateway_ip() {
    local gateway_ip=""

    if [[ "$OSTYPE" == "darwin"* ]]; then
        # macOS
        gateway_ip=$(route -n get default 2>/dev/null | grep 'gateway:' | awk '{print $2}')
    elif command -v ip >/dev/null 2>&1; then
        # Linux with ip command
        gateway_ip=$(ip route show default 2>/dev/null | awk '/default/ {print $3}')
    elif command -v route >/dev/null 2>&1; then
        # Linux with route command
        gateway_ip=$(route -n 2>/dev/null | awk '/^0.0.0.0/ {print $2}')
    fi

    if [ -n "$gateway_ip" ]; then
        echo "$gateway_ip"
        return 0
    fi
    return 1
}

# Get gateway MAC address via ARP
get_gateway_mac() {
    local gateway_ip
    gateway_ip=$(get_gateway_ip)

    if [ -z "$gateway_ip" ]; then
        log_debug "Cannot determine gateway IP"
        return 1
    fi

    local mac=""

    if [[ "$OSTYPE" == "darwin"* ]]; then
        # macOS: arp -n <ip> returns "? (192.168.1.1) at aa:bb:cc:dd:ee:ff on en0 ..."
        mac=$(arp -n "$gateway_ip" 2>/dev/null | awk '{print $4}')
    elif command -v ip >/dev/null 2>&1; then
        # Linux with ip command
        mac=$(ip neigh show "$gateway_ip" 2>/dev/null | awk '{print $5}')
    elif command -v arp >/dev/null 2>&1; then
        # Linux with arp command
        mac=$(arp -n "$gateway_ip" 2>/dev/null | awk 'NR>1 {print $3}')
    fi

    # Normalize MAC address to lowercase
    if [ -n "$mac" ] && [ "$mac" != "(incomplete)" ]; then
        echo "$mac" | tr '[:upper:]' '[:lower:]'
        return 0
    fi

    return 1
}

# Check if current gateway MAC matches any home gateway MAC
is_home_gateway_mac() {
    local current_mac="$1"

    if [ -z "$current_mac" ] || [ -z "$HOME_GATEWAY_MAC" ]; then
        return 1
    fi

    # Normalize current MAC to lowercase
    current_mac=$(echo "$current_mac" | tr '[:upper:]' '[:lower:]')

    # Split HOME_GATEWAY_MAC by comma and check each
    IFS=',' read -ra macs <<< "$HOME_GATEWAY_MAC"
    for mac in "${macs[@]}"; do
        # Trim whitespace and normalize to lowercase
        mac=$(echo "$mac" | xargs | tr '[:upper:]' '[:lower:]')
        if [ "$current_mac" = "$mac" ]; then
            return 0
        fi
    done
    return 1
}

# Get current local IP address
get_current_ip() {
    local ip
    
    if [[ "$OSTYPE" == "darwin"* ]]; then
        # macOS
        local default_interface=$(route get default 2>/dev/null | grep interface: | awk '{print $2}')
        if [ -n "$default_interface" ]; then
            ip=$(ifconfig "$default_interface" 2>/dev/null | grep 'inet ' | grep -v '127.0.0.1' | head -1 | awk '{print $2}')
        fi
    elif grep -qi "microsoft.*wsl\|wsl.*microsoft" /proc/version 2>/dev/null || command -v powershell.exe >/dev/null 2>&1; then
        # WSL2 - get Windows host WiFi IP (not WSL2 internal IP)
        ip=$(powershell.exe -Command "
            \$wifiAdapter = Get-NetAdapter | Where-Object {\$_.InterfaceDescription -like '*Wi-Fi*' -and \$_.Status -eq 'Up'}
            if (\$wifiAdapter) {
                \$ipConfig = Get-NetIPAddress -InterfaceIndex \$wifiAdapter.InterfaceIndex -AddressFamily IPv4 | Where-Object {\$_.AddressState -eq 'Preferred' -and \$_.IPAddress -notlike '169.254.*'}
                if (\$ipConfig) {
                    \$ipConfig.IPAddress
                } else {
                    'NOT_CONNECTED'
                }
            } else {
                'NOT_CONNECTED'
            }
        " 2>/dev/null | tr -d '\r\n')
    elif command -v ip >/dev/null 2>&1; then
        # Linux with ip command
        ip=$(ip route get 8.8.8.8 2>/dev/null | grep -oP 'src \K\S+')
    elif command -v ifconfig >/dev/null 2>&1; then
        # Linux/Unix with ifconfig
        ip=$(ifconfig 2>/dev/null | grep 'inet ' | grep -v '127.0.0.1' | head -1 | awk '{print $2}' | sed 's/addr://')
    else
        echo "Error: Cannot determine local IP address" >&2
        return 1
    fi
    
    if [ -z "$ip" ] || [ "$ip" = "127.0.0.1" ]; then
        echo "NOT_CONNECTED"
    else
        echo "$ip"
    fi
}

# Convert IP address to 32-bit integer
ip_to_int() {
    local ip="$1"
    local a b c d
    IFS='.' read -r a b c d <<< "$ip"
    echo $((a * 256 * 256 * 256 + b * 256 * 256 + c * 256 + d))
}

# Check if IP is in CIDR range using integer comparison
ip_in_cidr() {
    local ip="$1"
    local cidr="$2"

    # Validate CIDR format
    if ! validate_cidr "$cidr"; then
        return 1
    fi

    # Validate IP address
    if ! validate_ip "$ip"; then
        print_error "Error: Invalid IP address: $ip"
        return 1
    fi

    local network=$(echo "$cidr" | cut -d'/' -f1)
    local mask_bits=$(echo "$cidr" | cut -d'/' -f2)

    # Convert IP and network to integers
    local ip_int=$(ip_to_int "$ip")
    local network_int=$(ip_to_int "$network")

    # Calculate network mask
    local mask=$((0xFFFFFFFF << (32 - mask_bits)))

    # Apply mask to both IP and network
    local ip_network=$((ip_int & mask))
    local cidr_network=$((network_int & mask))

    # Check if they match
    [ "$ip_network" -eq "$cidr_network" ]
}

# Check if current IP is in home network ranges
is_home_network() {
    local current_ip="$1"
    
    # Check if IP is valid
    if [ "$current_ip" = "NOT_CONNECTED" ] || [ -z "$current_ip" ]; then
        return 1
    fi
    
    # Split HOME_NETWORK by comma and check each network
    IFS=',' read -ra networks <<< "$HOME_NETWORK"
    for network in "${networks[@]}"; do
        # Trim whitespace
        network=$(echo "$network" | xargs)
        if ip_in_cidr "$current_ip" "$network"; then
            return 0
        fi
    done
    return 1
}

# Resolve hostname to IP address using available DNS tools
# Try each tool in sequence until one succeeds, since some tools
# (e.g., dig) bypass the system resolver and may miss Tailscale MagicDNS
resolve_hostname() {
    local hostname="$1"
    local resolved_ip=""

    # host uses system resolver (works with Tailscale MagicDNS)
    if [ -z "$resolved_ip" ] && command -v host >/dev/null 2>&1; then
        resolved_ip=$(host -t A "$hostname" 2>/dev/null | awk '/has address/ {print $4}' | head -1)
    fi

    # dig may bypass system resolver, but try as fallback
    if [ -z "$resolved_ip" ] && command -v dig >/dev/null 2>&1; then
        resolved_ip=$(dig +short "$hostname" A 2>/dev/null | grep -E '^[0-9]+\.' | head -1)
    fi

    # getent uses system resolver (NSS)
    if [ -z "$resolved_ip" ] && command -v getent >/dev/null 2>&1; then
        resolved_ip=$(getent hosts "$hostname" 2>/dev/null | awk '{print $1}' | head -1)
    fi

    if [ -n "$resolved_ip" ]; then
        echo "$resolved_ip"
        return 0
    fi
    return 1
}

# Check if the SSH target host is a Tailscale node
# Tailscale uses CGNAT range 100.64.0.0/10 and MagicDNS *.ts.net
is_tailscale_host() {
    local hostname="$1"

    # Get resolved HostName from SSH config
    local resolved_host
    resolved_host=$(ssh -G "$hostname" 2>/dev/null | awk '/^hostname / {print $2}')

    if [ -z "$resolved_host" ]; then
        return 1
    fi

    log_debug "Tailscale check: resolved HostName=$resolved_host"

    # Check if HostName is a Tailscale MagicDNS name (*.ts.net)
    if [[ "$resolved_host" == *.ts.net ]]; then
        log_debug "Tailscale detected: MagicDNS hostname ($resolved_host)"
        return 0
    fi

    # Check if HostName is an IP in Tailscale CGNAT range (100.64.0.0/10)
    if validate_ip "$resolved_host"; then
        if ip_in_cidr "$resolved_host" "100.64.0.0/10"; then
            log_debug "Tailscale detected: CGNAT IP ($resolved_host)"
            return 0
        fi
        return 1
    fi

    # HostName is a non-ts.net hostname; try DNS resolution
    local resolved_ip
    resolved_ip=$(resolve_hostname "$resolved_host")
    if [ -n "$resolved_ip" ] && validate_ip "$resolved_ip"; then
        if ip_in_cidr "$resolved_ip" "100.64.0.0/10"; then
            log_debug "Tailscale detected: DNS resolved to CGNAT IP ($resolved_host -> $resolved_ip)"
            return 0
        fi
    fi

    return 1
}

# Check required dependencies for OIDC Device Flow
check_oidc_dependencies() {
    local missing=()

    if ! command -v jq >/dev/null 2>&1; then
        missing+=("jq")
    fi
    if ! command -v curl >/dev/null 2>&1; then
        missing+=("curl")
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        log_error "OIDC requires missing dependencies: ${missing[*]}"
        log_error "Install them and try again."
        return 1
    fi
    return 0
}

# Validate that OIDC_ISSUER and OIDC_CA_URL use https:// scheme
validate_oidc_urls() {
    if [ -z "$OIDC_ISSUER" ] || [[ "$OIDC_ISSUER" != https://* ]]; then
        log_error "OIDC_ISSUER must be set and start with https:// (got: '${OIDC_ISSUER}')"
        return 1
    fi
    if [ -z "$OIDC_CA_URL" ] || [[ "$OIDC_CA_URL" != https://* ]]; then
        log_error "OIDC_CA_URL must be set and start with https:// (got: '${OIDC_CA_URL}')"
        return 1
    fi
    return 0
}

# Fetch OIDC discovery document and extract device/token endpoints
# Sets globals: _OIDC_DEVICE_ENDPOINT, _OIDC_TOKEN_ENDPOINT
oidc_discover() {
    local issuer="$1"
    local discovery_url="${issuer%/}/.well-known/openid-configuration"

    log_debug "OIDC discovery: $discovery_url"

    local response
    response=$(curl --fail --silent --show-error --max-time 30 --connect-timeout 10 \
        "$discovery_url" 2>&1)
    if [ $? -ne 0 ]; then
        log_error "OIDC discovery request failed: $response"
        return 2
    fi

    # Validate JSON and extract required fields
    if ! echo "$response" | jq -e . >/dev/null 2>&1; then
        log_error "OIDC discovery returned malformed JSON"
        return 2
    fi

    local device_endpoint token_endpoint
    device_endpoint=$(echo "$response" | jq -r '.device_authorization_endpoint // empty')
    token_endpoint=$(echo "$response" | jq -r '.token_endpoint // empty')

    if [ -z "$device_endpoint" ]; then
        log_error "OIDC discovery missing device_authorization_endpoint"
        return 2
    fi
    if [ -z "$token_endpoint" ]; then
        log_error "OIDC discovery missing token_endpoint"
        return 2
    fi

    # Extract origin (scheme://host:port) from issuer for Token Relay attack prevention
    # Strip path and trailing slash to get scheme://host[:port]
    local issuer_origin
    issuer_origin=$(echo "$issuer" | sed -E 's|^(https?://[^/]+).*|\1|')

    # Validate that endpoints belong to the same origin as the issuer
    if [[ "$device_endpoint" != "${issuer_origin}"/* ]] && [ "$device_endpoint" != "$issuer_origin" ]; then
        log_error "device_authorization_endpoint origin mismatch: expected $issuer_origin, got $device_endpoint"
        return 2
    fi
    if [[ "$token_endpoint" != "${issuer_origin}"/* ]] && [ "$token_endpoint" != "$issuer_origin" ]; then
        log_error "token_endpoint origin mismatch: expected $issuer_origin, got $token_endpoint"
        return 2
    fi

    _OIDC_DEVICE_ENDPOINT="$device_endpoint"
    _OIDC_TOKEN_ENDPOINT="$token_endpoint"
    log_debug "device_authorization_endpoint: $_OIDC_DEVICE_ENDPOINT"
    log_debug "token_endpoint: $_OIDC_TOKEN_ENDPOINT"
    return 0
}

# Send Device Authorization Request and display user_code + verification_uri
# Sets globals: _OIDC_DEVICE_CODE, _OIDC_USER_CODE, _OIDC_VERIFICATION_URI,
#               _OIDC_EXPIRES_IN, _OIDC_POLL_INTERVAL
oidc_device_authorize() {
    local response
    response=$(curl --fail --silent --show-error --max-time 30 --connect-timeout 10 \
        -X POST "$_OIDC_DEVICE_ENDPOINT" \
        --data-urlencode "client_id=${OIDC_CLIENT_ID}" \
        --data-urlencode "scope=${OIDC_SCOPES}" 2>&1)
    if [ $? -ne 0 ]; then
        log_error "Device authorization request failed: $response"
        return 2
    fi

    if ! echo "$response" | jq -e . >/dev/null 2>&1; then
        log_error "Device authorization returned malformed JSON"
        return 2
    fi

    _OIDC_DEVICE_CODE=$(echo "$response" | jq -r '.device_code // empty')
    _OIDC_USER_CODE=$(echo "$response" | jq -r '.user_code // empty')
    _OIDC_VERIFICATION_URI=$(echo "$response" | jq -r '.verification_uri // empty')
    _OIDC_EXPIRES_IN=$(echo "$response" | jq -r '.expires_in // 300')
    _OIDC_POLL_INTERVAL=$(echo "$response" | jq -r '.interval // 5')

    if [ -z "$_OIDC_DEVICE_CODE" ] || [ -z "$_OIDC_USER_CODE" ] || [ -z "$_OIDC_VERIFICATION_URI" ]; then
        log_error "Device authorization response missing required fields"
        return 2
    fi

    echo ""
    print_info "=== OIDC Device Authentication ==="
    print_info "Open this URL in your browser:"
    print_info "  $_OIDC_VERIFICATION_URI"
    print_info ""
    print_info "Enter this code: $_OIDC_USER_CODE"
    print_info "=================================="
    echo ""
    return 0
}

# Poll token endpoint until access granted, error, or timeout (RFC 8628)
# Sets global: _OIDC_ID_TOKEN
# Returns: 0 on success, 2 on network error, 3 on access_denied/expired_token/timeout
oidc_poll_token() {
    # Allow test overrides; minimum enforced interval is 5 seconds
    local server_interval="${_OIDC_POLL_INTERVAL:-5}"
    local current_interval
    # Enforce client-side minimum of 5 seconds
    if [ "$server_interval" -lt 5 ] 2>/dev/null; then
        current_interval=5
    else
        current_interval="$server_interval"
    fi

    local expires_in="${_OIDC_EXPIRES_IN:-300}"
    local timeout="${_OIDC_POLL_TIMEOUT_OVERRIDE:-$expires_in}"
    local elapsed=0

    # _OIDC_POLL_TIMEOUT_OVERRIDE=0 means immediate timeout
    if [ "$timeout" -eq 0 ] 2>/dev/null; then
        log_error "OIDC polling timed out waiting for authorization"
        return 3
    fi

    log_info "Waiting for authorization (timeout: ${timeout}s)..."

    while [ "$elapsed" -lt "$timeout" ]; do
        local sleep_time="${_OIDC_POLL_INTERVAL_OVERRIDE:-$current_interval}"

        sleep "$sleep_time"
        # Ensure elapsed always advances to prevent infinite loop
        local increment=$(( sleep_time > 0 ? sleep_time : 1 ))
        elapsed=$((elapsed + increment))

        # Do NOT use --fail here: RFC 8628 returns HTTP 400 for
        # authorization_pending/slow_down which are expected responses
        local response http_code
        response=$(curl --silent --show-error --max-time 30 --connect-timeout 10 \
            -w '\n%{http_code}' \
            -X POST "$_OIDC_TOKEN_ENDPOINT" \
            --data-urlencode "grant_type=urn:ietf:params:oauth:grant-type:device_code" \
            --data-urlencode "device_code=${_OIDC_DEVICE_CODE}" \
            --data-urlencode "client_id=${OIDC_CLIENT_ID}" 2>&1)
        local curl_exit=$?

        # Network-level error (curl itself failed)
        if [ $curl_exit -ne 0 ]; then
            log_error "Token poll request failed: $response"
            return 2
        fi

        # Extract HTTP status code (last line) and response body
        http_code=$(echo "$response" | tail -1)
        response=$(echo "$response" | sed '$d')

        # HTTP 5xx or non-JSON response: server error
        if [ "${http_code:-0}" -ge 500 ]; then
            log_error "Token endpoint server error (HTTP $http_code)"
            return 2
        fi

        if ! echo "$response" | jq -e . >/dev/null 2>&1; then
            log_error "Token endpoint returned malformed response"
            return 2
        fi

        local error id_token
        error=$(echo "$response" | jq -r '.error // empty')
        id_token=$(echo "$response" | jq -r '.id_token // empty')

        if [ -z "$error" ] && [ -n "$id_token" ]; then
            _OIDC_ID_TOKEN="$id_token"
            log_debug "ID token obtained (length: ${#id_token})"
            return 0
        fi

        case "$error" in
            authorization_pending)
                log_debug "Authorization pending, retrying in ${current_interval}s..."
                ;;
            slow_down)
                current_interval=$((current_interval + 5))
                log_debug "Server requested slow_down, new interval: ${current_interval}s"
                ;;
            access_denied)
                log_error "OIDC authorization denied by user"
                return 3
                ;;
            expired_token)
                log_error "OIDC device code expired"
                return 3
                ;;
            "")
                # No error but also no id_token; treat as pending
                log_debug "Token response missing both error and id_token, retrying..."
                ;;
            *)
                log_error "OIDC token error: $error"
                return 3
                ;;
        esac
    done

    log_error "OIDC polling timed out waiting for authorization"
    return 3
}

# Send ID token to CA API and save certificate + key files
# Reads _OIDC_ID_TOKEN; writes OIDC_CERT_DIR/id_oidc-cert.pub and id_oidc
oidc_get_certificate() {
    local cert_file="${OIDC_CERT_DIR}/id_oidc-cert.pub"
    local key_file="${OIDC_CERT_DIR}/id_oidc"
    # CA endpoint: use OIDC_CA_URL as-is (user specifies full path)
    local ca_endpoint="${OIDC_CA_URL%/}/ssh/sign"

    log_debug "Requesting SSH certificate from CA: $ca_endpoint"

    # Generate a new ephemeral key pair for the certificate
    # NOTE: Do not use 'trap RETURN' here - it would override the caller's trap
    local temp_key
    temp_key=$(umask 077 && mktemp)

    if ! ssh-keygen -t ed25519 -f "$temp_key" -N "" -q >/dev/null 2>&1; then
        log_error "Failed to generate ephemeral key pair"
        rm -f "$temp_key" "${temp_key}.pub"
        return 1
    fi

    local pub_key
    pub_key=$(cat "${temp_key}.pub")

    # Build JSON request body safely using jq
    local json_body
    json_body=$(jq -n \
        --arg pk "$pub_key" \
        --arg prov "$OIDC_CA_PROVISIONER" \
        --arg lifetime "+${OIDC_CERT_LIFETIME}s" \
        '{"publicKey":$pk,"certType":"user","provisioner":$prov,"validAfter":"","validBefore":$lifetime}')

    # Send ID token via stdin to avoid cmdline exposure
    local response
    response=$(printf 'Authorization: Bearer %s' "$_OIDC_ID_TOKEN" | \
        curl --fail --silent --show-error --max-time 30 --connect-timeout 10 \
        -X POST "$ca_endpoint" \
        -H @- \
        -H "Content-Type: application/json" \
        -d "$json_body" 2>&1)
    local curl_exit=$?

    if [ $curl_exit -ne 0 ]; then
        log_error "CA certificate request failed: $response"
        rm -f "$temp_key" "${temp_key}.pub"
        return 2
    fi

    if ! echo "$response" | jq -e . >/dev/null 2>&1; then
        log_error "CA returned malformed JSON"
        rm -f "$temp_key" "${temp_key}.pub"
        return 2
    fi

    local cert
    cert=$(echo "$response" | jq -r '.crt // empty')
    if [ -z "$cert" ]; then
        log_error "CA response missing certificate (crt field)"
        rm -f "$temp_key" "${temp_key}.pub"
        return 2
    fi

    # Save certificate and private key with secure permissions
    (umask 077 && printf '%s\n' "$cert" > "$cert_file") || {
        log_error "Failed to write certificate file: $cert_file"
        rm -f "$temp_key" "${temp_key}.pub"
        return 2
    }
    (umask 077 && cp "$temp_key" "$key_file") || {
        log_error "Failed to write key file: $key_file"
        rm -f "$temp_key" "${temp_key}.pub"
        return 2
    }
    chmod 600 "$cert_file" "$key_file"

    # Clean up ephemeral key pair
    rm -f "$temp_key" "${temp_key}.pub"

    log_debug "Certificate saved: $cert_file"
    log_debug "Key saved: $key_file"
    return 0
}

# Check if a valid cached certificate and its corresponding key exist
# Returns 0 if both exist and certificate has not expired
oidc_check_cached_cert() {
    local cert_file="${OIDC_CERT_DIR}/id_oidc-cert.pub"
    local key_file="${OIDC_CERT_DIR}/id_oidc"

    if [ ! -f "$cert_file" ] || [ ! -f "$key_file" ]; then
        log_debug "No cached OIDC certificate or key found"
        return 1
    fi

    # Extract validity end time from certificate
    local valid_to_str
    valid_to_str=$(ssh-keygen -L -f "$cert_file" 2>/dev/null | grep "Valid:" | sed 's/.*to //')
    if [ -z "$valid_to_str" ]; then
        log_debug "Cannot parse certificate validity"
        return 1
    fi

    # Convert to epoch seconds (macOS vs Linux)
    local valid_to_epoch
    if [[ "$OSTYPE" == "darwin"* ]]; then
        valid_to_epoch=$(date -jf "%Y-%m-%dT%H:%M:%S" "$valid_to_str" "+%s" 2>/dev/null)
    else
        valid_to_epoch=$(date -d "$valid_to_str" "+%s" 2>/dev/null)
    fi

    if [ -z "$valid_to_epoch" ]; then
        log_debug "Cannot convert certificate expiry to epoch: '$valid_to_str'"
        return 1
    fi

    local now_epoch
    now_epoch=$(date "+%s")

    if [ "$now_epoch" -lt "$valid_to_epoch" ]; then
        log_debug "Cached certificate is valid (expires at $valid_to_str)"
        return 0
    fi

    log_debug "Cached certificate has expired (expired at $valid_to_str)"
    return 1
}

# Create certificate directory with secure permissions
# Creates ~/.ssh/ if needed (chmod 700), then OIDC_CERT_DIR (chmod 700)
# Verifies no symlinks in the path
ensure_oidc_cert_dir() {
    local ssh_dir="$HOME/.ssh"

    # Reject symlinks for security (check before mkdir)
    if [ -L "$ssh_dir" ]; then
        log_error "Security error: $ssh_dir is a symlink"
        return 1
    fi

    # Create ~/.ssh if it does not exist
    if [ ! -e "$ssh_dir" ]; then
        mkdir -m 700 "$ssh_dir" || {
            log_error "Failed to create $ssh_dir"
            return 1
        }
    fi

    # Reject symlinks for security (check before mkdir)
    if [ -L "$OIDC_CERT_DIR" ]; then
        log_error "Security error: $OIDC_CERT_DIR is a symlink"
        return 1
    fi

    # Create OIDC cert directory
    if [ ! -e "$OIDC_CERT_DIR" ]; then
        mkdir -m 700 "$OIDC_CERT_DIR" || {
            log_error "Failed to create OIDC cert directory: $OIDC_CERT_DIR"
            return 1
        }
    fi

    if [ ! -d "$OIDC_CERT_DIR" ]; then
        log_error "OIDC_CERT_DIR exists but is not a directory: $OIDC_CERT_DIR"
        return 1
    fi

    return 0
}

# Determine whether OIDC should be used for the current connection
should_use_oidc() {
    [ "$FORCE_OIDC" = true ] && return 0
    [ "$OIDC_ENABLED" = "true" ] || return 1
    case "$OIDC_AUTH_MODE" in
        only|prefer) return 0 ;;
        auto) [ ! -f "$SECURITY_KEY_PATH" ] && return 0; return 1 ;;
        disabled|*) return 1 ;;
    esac
}

# Connect using OIDC Device Flow certificate authentication
ssh_with_oidc() {
    local hostname="$1"
    local dry_run="${2:-false}"
    shift 2
    local ssh_options=("$@")

    local cert_file="${OIDC_CERT_DIR}/id_oidc-cert.pub"
    local key_file="${OIDC_CERT_DIR}/id_oidc"

    # 1. Check prerequisites
    check_oidc_dependencies || return 1
    validate_oidc_urls || return 1

    # 2. Prepare certificate directory
    ensure_oidc_cert_dir || return 1

    # 3. Use cached certificate if still valid
    if oidc_check_cached_cert; then
        log_info "Using cached OIDC certificate"
    else
        # 4. Run OIDC Device Flow
        oidc_discover "$OIDC_ISSUER" || return 2
        oidc_device_authorize || return 2
        oidc_poll_token || return $?
        oidc_get_certificate || return 2
        log_info "SSH certificate obtained successfully"
    fi

    # 5. Build temporary SSH config and connect
    local temp_config
    temp_config=$(umask 077 && mktemp) || return 1
    trap 'rm -f "$temp_config"' RETURN INT TERM

    # Check if ProxyJump is configured
    local proxy_jump
    proxy_jump=$(ssh -G "$hostname" 2>/dev/null | grep "^proxyjump " | awk '{print $2}')

    if [ -n "$proxy_jump" ] && [ "$proxy_jump" != "none" ]; then
        log_debug "ProxyJump detected for OIDC: $proxy_jump"
        echo "Host $proxy_jump" >> "$temp_config"
        ssh -G "$proxy_jump" 2>/dev/null | \
            grep -E "^(hostname|port|user) " | \
            awk '{print "    " $1 " " $2}' >> "$temp_config"
        echo "    IdentityFile $key_file" >> "$temp_config"
        echo "    CertificateFile $cert_file" >> "$temp_config"
        echo "    IdentitiesOnly yes" >> "$temp_config"
        echo "    IdentityAgent none" >> "$temp_config"
        echo "" >> "$temp_config"

        echo "Host $hostname" >> "$temp_config"
        ssh -G "$hostname" 2>/dev/null | \
            grep -E "^(hostname|port|user|proxyjump|localforward|sessiontype|forkafterauthentication|requesttty|exitonforwardfailure) " | \
            awk '{printf "    %s", $1; for(i=2;i<=NF;i++) printf " %s", $i; print ""}' >> "$temp_config"
        echo "    IdentityFile $key_file" >> "$temp_config"
        echo "    CertificateFile $cert_file" >> "$temp_config"
        echo "    IdentitiesOnly yes" >> "$temp_config"
        echo "    IdentityAgent none" >> "$temp_config"
    else
        echo "Host $hostname" >> "$temp_config"
        ssh -G "$hostname" 2>/dev/null | \
            grep -E "^(hostname|port|user|localforward|sessiontype|forkafterauthentication|requesttty|exitonforwardfailure) " | \
            awk '{printf "    %s", $1; for(i=2;i<=NF;i++) printf " %s", $i; print ""}' >> "$temp_config"
        echo "    IdentityFile $key_file" >> "$temp_config"
        echo "    CertificateFile $cert_file" >> "$temp_config"
        echo "    IdentitiesOnly yes" >> "$temp_config"
        echo "    IdentityAgent none" >> "$temp_config"
    fi

    if [ "$dry_run" = true ]; then
        if [ ${#ssh_options[@]} -gt 0 ]; then
            print_info "[DRY RUN] Would execute: ssh -F $temp_config ${ssh_options[*]} $hostname"
        else
            print_info "[DRY RUN] Would execute: ssh -F $temp_config $hostname"
        fi
        print_info "[DRY RUN] Temporary SSH config:"
        while IFS= read -r line; do
            print_info "  $line"
        done < "$temp_config"
        return 0
    fi

    if [ ${#ssh_options[@]} -gt 0 ]; then
        log_debug "Executing: ssh -F $temp_config ${ssh_options[*]} $hostname"
        ssh -F "$temp_config" "${ssh_options[@]}" "$hostname"
    else
        log_debug "Executing: ssh -F $temp_config $hostname"
        ssh -F "$temp_config" "$hostname"
    fi
}

# Check SSH configuration exists (single host entry)
check_ssh_config() {
    local hostname="$1"
    
    # Use ssh -G to get actual configuration (handles Include directives)
    if ! ssh -G "$hostname" >/dev/null 2>&1; then
        echo "Warning: SSH configuration for '$hostname' not found"
        return 1
    fi
    
    return 0
}

# Connect from home (regular public key authentication)
ssh_from_home() {
    local hostname="$1"
    local dry_run="${2:-false}"
    shift 2
    local ssh_options=("$@")

    print_success "Home network connection detected. Connecting with regular public key authentication..."
    print_info "Target: $hostname"

    if [ "$dry_run" = true ]; then
        if [ ${#ssh_options[@]} -gt 0 ]; then
            print_debug "[DRY RUN] Would execute: ssh ${ssh_options[*]} $hostname"
